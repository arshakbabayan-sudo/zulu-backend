APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Browser CORS for `/api/*` (Next.js admin/storefront). Comma-separated origins, e.g.
# https://admin.example.com,https://shop.example.com — use * only for local dev.
CORS_ALLOWED_ORIGINS=*

# Must stay false for Bearer-only separated clients. If ever true, set explicit
# CORS_ALLOWED_ORIGINS (never *) and adopt cookie credentials intentionally.
# CORS_SUPPORTS_CREDENTIALS=false

# Optional. Default merges localhost, APP_URL host, etc. Only domains that use
# Laravel session + Sanctum cookie SPA flows belong here — not required for PAT/Bearer API clients.
# SANCTUM_STATEFUL_DOMAINS=

# Shadow rollout: super-admin entry to Next admin at /admin-next (Blade /admin unchanged).
# ADMIN_NEXT_ENABLED=false
# ADMIN_NEXT_ORIGIN=http://127.0.0.1:3000
# ADMIN_NEXT_HEALTH_PATH=/
# ADMIN_NEXT_HEALTH_TIMEOUT=2

# R2 pilot: restrict Next bridge to allowlisted super-admins (comma-separated). Either list may be empty if the other is used; both empty while pilot mode is on denies everyone (cohort_not_configured).
# ADMIN_NEXT_R2_PILOT_MODE=false
# ADMIN_NEXT_R2_ALLOW_EMAILS=ops@example.com,pilot@example.com
# ADMIN_NEXT_R2_ALLOW_USER_IDS=1,2

# Rollback drill: same log pattern as Next unreachable (next_unreachable) without calling the origin. Remove after verification.
# ADMIN_NEXT_ROLLBACK_DRILL_SIMULATE_UNREACHABLE=false

# Service Connections advanced rollout (Step 3.4)
# SERVICE_CONNECTIONS_ADVANCED_ENABLED=true
# SERVICE_CONNECTIONS_REQUIRE_NOTES_FOR_REJECT=true
# SERVICE_CONNECTIONS_REQUIRE_NOTES_FOR_CANCEL=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@zuluspin.com"
MAIL_FROM_NAME="ZULU SPIN"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAYMENT_DRIVER=stripe
STRIPE_KEY=pk_test_your_key_here
STRIPE_SECRET=sk_test_your_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=usd
